{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vera.local/schemas/cascade-advisory.schema.json",
  "title": "VERA Cascade Advisory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "advisory_id",
    "generated_at",
    "triggering_event",
    "reasoning",
    "affected_assets",
    "advisories",
    "confidence",
    "data_sources",
    "caveats"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "vera.cascade_advisory.v1"
    },
    "advisory_id": {
      "type": "string",
      "description": "Stable app-side identifier for this advisory."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when the advisory was produced."
    },
    "triggering_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "asset_id",
        "asset_label",
        "latitude",
        "longitude",
        "occurred_at",
        "current_state",
        "event_confidence",
        "evidence_summary"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "enum": ["attack", "outage", "fire", "flood", "equipment_failure", "planned_shutdown", "unknown"]
        },
        "asset_id": { "type": ["string", "null"] },
        "asset_label": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"] },
        "longitude": { "type": ["number", "null"] },
        "occurred_at": { "type": ["string", "null"] },
        "current_state": {
          "type": "string",
          "enum": ["operational", "degraded", "offline", "unknown"]
        },
        "event_confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "evidence_summary": { "type": "string" }
      }
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "description": "The analyst's own thinking on top of the dependency graph.",
      "required": [
        "narrative",
        "graph_edges_trusted",
        "graph_edges_doubted",
        "inferred_dependencies",
        "key_unknowns"
      ],
      "properties": {
        "narrative": {
          "type": "string",
          "description": "Plain-language reasoning, written as an operator thinking out loud."
        },
        "graph_edges_trusted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "graph_edges_doubted": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Edges the dependency graph asserts that the analyst doubts, with reasons."
        },
        "inferred_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dependencies the graph misses but physical logic implies."
        },
        "key_unknowns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "affected_assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/affected_asset" }
    },
    "advisories": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/advisory" }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "score", "drivers", "verification_required"],
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "drivers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification_required": { "type": "boolean" }
      }
    },
    "data_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/data_source" }
    },
    "caveats": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "expected", "high", "unit"],
      "properties": {
        "low": { "type": ["number", "null"] },
        "expected": { "type": ["number", "null"] },
        "high": { "type": ["number", "null"] },
        "unit": { "type": "string", "enum": ["minutes", "hours", "days"] }
      }
    },
    "affected_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "asset_label",
        "service_lost",
        "dependency_source",
        "buffer_assumption",
        "time_to_impact",
        "timing_class",
        "severity",
        "population_exposed"
      ],
      "properties": {
        "asset_id": { "type": ["string", "null"] },
        "asset_label": { "type": "string" },
        "service_lost": {
          "type": "string",
          "enum": ["water", "power", "heat", "transport_access", "comms", "fuel", "other"]
        },
        "dependency_source": {
          "type": "string",
          "enum": ["graph", "inferred"],
          "description": "Whether this dependency came from the model or from the analyst's own reasoning."
        },
        "buffer_assumption": {
          "type": "string",
          "description": "The reserve/redundancy assumption used to estimate timing, e.g. '4-8h on-site water reserve'."
        },
        "time_to_impact": { "$ref": "#/$defs/time_window" },
        "timing_class": {
          "type": "string",
          "enum": ["immediate", "delayed", "conditional", "unknown"]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "moderate", "high", "critical"]
        },
        "population_exposed": { "type": ["number", "null"] }
      }
    },
    "advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "headline",
        "recipient_role",
        "recipient_asset_id",
        "urgency",
        "notify_before",
        "recommended_action",
        "rationale"
      ],
      "properties": {
        "id": { "type": "string" },
        "headline": {
          "type": "string",
          "description": "One-line warning, e.g. 'Hospital No.7 may lose water access in ~6h'."
        },
        "recipient_role": {
          "type": "string",
          "description": "Who to warn, e.g. 'hospital duty officer', 'city operations', 'water dispatcher'."
        },
        "recipient_asset_id": { "type": ["string", "null"] },
        "urgency": { "type": "string", "enum": ["info", "advisory", "urgent", "critical"] },
        "notify_before": {
          "type": ["string", "null"],
          "description": "Deadline to notify, ahead of the impact window. ISO 8601 or relative text."
        },
        "recommended_action": {
          "type": "string",
          "description": "Concrete action the recipient should take."
        },
        "rationale": { "type": "string" }
      }
    },
    "data_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "path_or_url", "used_for", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["dependency_graph", "damage_state", "local_dataset", "operator_input", "field_report", "assumption", "external_reference"]
        },
        "path_or_url": { "type": ["string", "null"] },
        "used_for": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    }
  }
}
