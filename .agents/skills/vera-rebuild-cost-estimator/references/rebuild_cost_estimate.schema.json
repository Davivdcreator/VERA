{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vera.local/schemas/rebuild-cost-estimate.schema.json",
  "title": "VERA Rebuild Cost Estimate",
  "description": "Canonical, dependency-aware rebuild-cost estimate. Strict-output safe: every object sets additionalProperties:false and lists all keys in required (no min/max/length keywords), so it can be passed verbatim as an OpenRouter response_format json_schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary",
    "target",
    "viability",
    "dependencies",
    "target_cost",
    "total_program_cost",
    "line_items",
    "assumptions",
    "risks",
    "missing_inputs",
    "recommended_next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "vera.rebuild_cost_estimate.v2"
    },
    "summary": {
      "type": "string",
      "description": "Plain-language summary (3-6 sentences): what the target is, whether it is viable to rebuild now, the headline expected program cost with range, the main blocking dependencies, and confidence. This is shown verbatim in the app."
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "location", "asset_type", "scope_summary"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": ["string", "null"] },
        "asset_type": { "type": "string" },
        "scope_summary": { "type": "string" }
      }
    },
    "viability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_viable_now", "reason", "blocking_dependencies", "critical_path"],
      "properties": {
        "is_viable_now": { "type": "boolean" },
        "reason": { "type": "string" },
        "blocking_dependencies": { "type": "array", "items": { "type": "string" } },
        "critical_path": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered dependency names that must be rebuilt first, ending with the target name."
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency" }
    },
    "target_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "low", "expected", "high", "confidence", "basis_date"],
      "properties": {
        "currency": { "type": "string" },
        "low": { "type": "number" },
        "expected": { "type": "number" },
        "high": { "type": "number" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "basis_date": { "type": "string", "description": "YYYY-MM-DD price basis date." }
      }
    },
    "total_program_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "low", "expected", "high", "includes_dependencies"],
      "properties": {
        "currency": { "type": "string" },
        "low": { "type": "number" },
        "expected": { "type": "number" },
        "high": { "type": "number" },
        "includes_dependencies": { "type": "boolean" }
      }
    },
    "line_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/line_item" }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "missing_inputs": { "type": "array", "items": { "type": "string" } },
    "recommended_next_steps": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "why_required_first",
        "rebuild_first",
        "cost",
        "assumptions",
        "missing_inputs"
      ],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "why_required_first": { "type": "string" },
        "rebuild_first": { "type": "boolean" },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["currency", "low", "expected", "high", "confidence"],
          "properties": {
            "currency": { "type": "string" },
            "low": { "type": "number" },
            "expected": { "type": "number" },
            "high": { "type": "number" },
            "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "missing_inputs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "line_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "category", "applies_to", "low", "expected", "high", "notes"],
      "properties": {
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "demolition",
            "hard_cost",
            "utilities",
            "soft_cost",
            "dependency",
            "contingency",
            "resilience",
            "other"
          ]
        },
        "applies_to": {
          "type": "string",
          "description": "The target name or a dependency name this line item belongs to."
        },
        "low": { "type": "number" },
        "expected": { "type": "number" },
        "high": { "type": "number" },
        "notes": { "type": "string" }
      }
    }
  }
}
