{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vera.local/schemas/rebuild-cost-estimate.schema.json",
  "title": "VERA Simple Rebuild Cost Estimate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "estimate_id",
    "estimate_kind",
    "summary",
    "location_context",
    "building_assumptions",
    "damage_assessment",
    "cost_model",
    "line_items",
    "totals",
    "confidence",
    "data_sources",
    "caveats",
    "recommended_next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "vera.rebuild_cost_estimate.v1"
    },
    "estimate_id": {
      "type": "string",
      "description": "Stable app-side identifier for this estimate."
    },
    "estimate_kind": {
      "type": "string",
      "enum": ["repair", "demolish_and_rebuild", "new_build", "unknown"]
    },
    "summary": {
      "type": "string"
    },
    "location_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "latitude",
        "longitude",
        "grid_id",
        "admin_area",
        "urban_context",
        "nearby_context"
      ],
      "properties": {
        "label": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"] },
        "longitude": { "type": ["number", "null"] },
        "grid_id": { "type": ["string", "null"] },
        "admin_area": { "type": ["string", "null"] },
        "urban_context": {
          "type": "string",
          "enum": ["central_dense", "urban", "suburban", "rural", "unknown"]
        },
        "nearby_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "population_estimate",
            "facility_count",
            "transit_stop_count",
            "hazard_exposure_notes"
          ],
          "properties": {
            "population_estimate": { "type": ["number", "null"] },
            "facility_count": { "type": ["integer", "null"] },
            "transit_stop_count": { "type": ["integer", "null"] },
            "hazard_exposure_notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "building_assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "building_use",
        "gross_floor_area_m2",
        "footprint_m2",
        "floors_above_grade",
        "basement_levels",
        "unit_count",
        "occupancy_estimate",
        "structure_type",
        "heritage_status",
        "assumption_notes"
      ],
      "properties": {
        "asset_id": { "type": ["string", "null"] },
        "building_use": {
          "type": "string",
          "enum": ["residential", "mixed_use", "school", "healthcare", "public_service", "utility", "unknown"]
        },
        "gross_floor_area_m2": { "type": ["number", "null"] },
        "footprint_m2": { "type": ["number", "null"] },
        "floors_above_grade": { "type": ["integer", "null"] },
        "basement_levels": { "type": ["integer", "null"] },
        "unit_count": { "type": ["integer", "null"] },
        "occupancy_estimate": { "type": ["integer", "null"] },
        "structure_type": {
          "type": "string",
          "enum": ["reinforced_concrete", "masonry", "panel", "steel", "timber", "unknown"]
        },
        "heritage_status": {
          "type": "string",
          "enum": ["listed", "possible", "not_listed", "unknown"]
        },
        "assumption_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "damage_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "damage_ratio",
        "damage_grade",
        "demolition_required",
        "evidence_summary",
        "inspection_status"
      ],
      "properties": {
        "damage_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "damage_grade": {
          "type": "string",
          "enum": ["minor", "moderate", "severe", "destroyed", "unknown"]
        },
        "demolition_required": { "type": ["boolean", "null"] },
        "evidence_summary": { "type": "string" },
        "inspection_status": {
          "type": "string",
          "enum": ["not_inspected", "remote_only", "field_observed", "engineer_verified", "unknown"]
        }
      }
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "price_basis_date",
        "vat_included",
        "base_rebuild_cost_per_m2",
        "demolition_cost_per_m2",
        "soft_cost_rate",
        "external_works_rate",
        "contingency_rate",
        "method_notes"
      ],
      "properties": {
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "price_basis_date": { "type": "string" },
        "vat_included": { "type": ["boolean", "null"] },
        "base_rebuild_cost_per_m2": { "$ref": "#/$defs/range" },
        "demolition_cost_per_m2": { "$ref": "#/$defs/range" },
        "soft_cost_rate": { "$ref": "#/$defs/range" },
        "external_works_rate": { "$ref": "#/$defs/range" },
        "contingency_rate": { "$ref": "#/$defs/range" },
        "method_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/line_item" }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "low", "expected", "high", "per_square_meter"],
      "properties": {
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "low": { "type": "number" },
        "expected": { "type": "number" },
        "high": { "type": "number" },
        "per_square_meter": { "$ref": "#/$defs/range" }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "score", "drivers", "verification_required"],
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "drivers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification_required": { "type": "boolean" }
      }
    },
    "data_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/data_source" }
    },
    "caveats": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "expected", "high"],
      "properties": {
        "low": { "type": "number" },
        "expected": { "type": "number" },
        "high": { "type": "number" }
      }
    },
    "line_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "category",
        "quantity",
        "unit",
        "unit_cost",
        "total",
        "confidence",
        "notes"
      ],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "demolition_debris_and_site_safety",
            "new_build_hard_cost",
            "utilities_and_external_works",
            "design_permits_supervision",
            "resilience_and_accessibility_upgrades",
            "temporary_housing_or_relocation",
            "heritage_or_complex_site_premium",
            "contingency_and_escalation",
            "other"
          ]
        },
        "quantity": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "unit_cost": { "$ref": "#/$defs/range" },
        "total": { "$ref": "#/$defs/range" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" }
      }
    },
    "data_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "path_or_url", "used_for", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["local_dataset", "official_report", "operator_input", "field_inspection", "assumption", "external_reference"]
        },
        "path_or_url": { "type": ["string", "null"] },
        "used_for": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    }
  }
}
