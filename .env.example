# VERA environment — copy to ".env" and fill in.
# The SPA reads Supabase with the anon key. Ingestion (FIRMS/Telegram) runs
# server-side and uses the service-role key + provider keys below — these must
# NOT be prefixed VITE_ (that would ship them to the browser).

# ── Client (SPA) — safe to expose ──────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Map Tiles API key — Photorealistic 3D Tiles renderer.
# Enable "Map Tiles API" + billing. https://developers.google.com/maps/documentation/tile/3d-tiles
VITE_GOOGLE_MAPS_API_KEY=

# ── Server-side ingestion (Edge Functions / scripts) — keep secret ─────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NASA FIRMS — fire/thermal damage detection.
# Get a key: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Valkyrie Telegram search — damage corroboration (text reports).
# Sent as the Authorization header to https://tg-search.valkyrie.org.ua
TELEGRAM_API_KEY=
